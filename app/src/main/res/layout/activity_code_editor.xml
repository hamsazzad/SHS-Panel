<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Toolbar -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:background="@drawable/glass_header"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/btn_icon_bg"
            android:src="@drawable/ic_arrow_back"
            android:padding="8dp"
            android:contentDescription="Back" />

        <TextView
            android:id="@+id/tvFileName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:paddingHorizontal="8dp"
            android:singleLine="true"
            android:ellipsize="middle" />

        <ImageButton
            android:id="@+id/btnSearch"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/btn_icon_bg"
            android:src="@drawable/ic_search"
            android:padding="7dp"
            android:contentDescription="Search" />

        <ImageButton
            android:id="@+id/btnUndo"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/btn_icon_bg"
            android:src="@drawable/ic_undo"
            android:padding="7dp"
            android:layout_marginStart="4dp"
            android:contentDescription="Undo" />

        <ImageButton
            android:id="@+id/btnRedo"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/btn_icon_bg"
            android:src="@drawable/ic_redo"
            android:padding="7dp"
            android:layout_marginStart="4dp"
            android:contentDescription="Redo" />

        <Button
            android:id="@+id/btnPreview"
            style="@style/GlassButton.Small"
            android:layout_marginStart="6dp"
            android:text="▶ Run" />

        <Button
            android:id="@+id/btnSave"
            style="@style/GlassButton.Accent"
            android:layout_marginStart="6dp"
            android:text="Save" />
    </LinearLayout>

    <!-- Progress -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="@color/accent_cyan"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- WebView Editor -->
    <WebView
        android:id="@+id/webEditor"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
