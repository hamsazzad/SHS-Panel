<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="4dp"
    app:cardBackgroundColor="@color/glass_bg"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:cardUseCompatPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Type indicator bar -->
        <View
            android:id="@+id/viewTypeIndicator"
            android:layout_width="3dp"
            android:layout_height="40dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/indicator_file" />

        <!-- File Icon -->
        <ImageView
            android:id="@+id/ivFileIcon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="14dp"
            android:src="@drawable/ic_file_generic"
            android:scaleType="centerCrop" />

        <!-- File Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvFileName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:singleLine="true"
                android:ellipsize="middle" />

            <TextView
                android:id="@+id/tvFileInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:layout_marginTop="2dp"
                android:singleLine="true" />
        </LinearLayout>

        <!-- Checkbox for multi-select -->
        <CheckBox
            android:id="@+id/cbSelect"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:visibility="gone"
            android:buttonTint="@color/accent_cyan" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
