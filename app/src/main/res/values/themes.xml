<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SHSPanel" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_cyan</item>
        <item name="colorOnPrimary">@color/bg_dark</item>
        <item name="colorSecondary">@color/accent_cyan</item>
        <item name="colorOnSecondary">@color/bg_dark</item>
        <item name="colorSurface">@color/glass_bg</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/statusBarColor</item>
        <item name="android:navigationBarColor">@color/navigationBarColor</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <style name="Theme.SHSPanel.Splash" parent="Theme.SHSPanel">
        <item name="android:windowNoTitle">true</item>
    </style>

    <style name="Theme.SHSPanel.Editor" parent="Theme.SHSPanel">
    </style>

    <style name="GlassDialog" parent="Theme.AppCompat.Dialog.Alert">
        <item name="colorPrimary">@color/accent_cyan</item>
        <item name="colorAccent">@color/accent_cyan</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
    </style>

    <style name="GlassButton" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/glass_bg</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="strokeColor">@color/glass_border</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">8dp</item>
        <item name="rippleColor">@color/accent_cyan_20</item>
    </style>

    <style name="GlassButton.Small">
        <item name="android:textSize">12sp</item>
        <item name="android:minHeight">32dp</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
    </style>

    <style name="GlassButton.Accent">
        <item name="backgroundTint">@color/accent_cyan</item>
        <item name="android:textColor">@color/bg_dark</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">12sp</item>
        <item name="android:minHeight">36dp</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="GlassButton.Small.Danger">
        <item name="backgroundTint">@color/accent_red</item>
        <item name="android:textColor">@color/white</item>
        <item name="strokeWidth">0dp</item>
    </style>
</resources>
